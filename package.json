{
  "name": "lander-browser",
  "version": "1.0.0",
  "description": "Lander Browser — privacy-first browser. Built-in ad blocking, tracker blocking, fingerprint resistance.",
  "main": "main.js",
  "scripts": {
    "start": "node launch.js",
    "dev": "node launch.js --inspect",
    "build": "electron-builder --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux AppImage --publish never",
    "build:linux:full": "electron-builder --linux AppImage deb rpm --publish never",
    "build:linux:rpm": "electron-builder --linux rpm --publish never",
    "build:flatpak": "electron-builder build --linux flatpak",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "browser",
    "electron",
    "privacy",
    "ad-block"
  ],
  "author": "Lander Browser",
  "license": "Custom",
  "dependencies": {
    "discord-rpc": "^4.0.1"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.lander.browser",
    "productName": "Lander Browser",
    "copyright": "Lander Browser",
    "files": [
      "main.js",
      "preload.js",
      "blocklist.js",
      "launch.js",
      "index.html",
      "incognito.html",
      "offline.html",
      "assets/**/*",
      "!**/node_modules/.cache/**",
      "wallpapers/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/logo.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "darkModeSupport": true
    },
    "win": {
      "icon": "assets/logo.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "assets/logo.png",
      "maintainer": "Lander Browser <support@landerbrowser.com>",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network;WebBrowser",
      "executableName": "lander-browser",
      "desktop": {
        "entry": {
          "Name": "Lander Browser",
          "Comment": "Privacy-first browser with built-in ad blocking"
        }
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/logo.ico",
      "uninstallerIcon": "assets/logo.ico",
      "include": "installer.nsh",
      "createStartMenuShortcut": true,
      "shortcutName": "Lander Browser"
    },
    "protocols": [
      {
        "name": "Lander Browser",
        "schemes": [
          "https",
          "http"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": "html",
        "name": "HTML Document",
        "description": "Open with Lander"
      },
      {
        "ext": "htm",
        "name": "HTML Document",
        "description": "Open with Lander"
      },
      {
        "ext": "xhtml",
        "name": "XHTML Document",
        "description": "Open with Lander"
      },
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "Open with Lander"
      }
    ]
  }
}
